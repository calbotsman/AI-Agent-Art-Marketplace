projects/hardware/

# Local state / caches (never commit)
logs/
node_modules/
**/node_modules/
**/.vite/
**/.vite-cache/
**/.next/
**/dist/
**/coverage/
**/*.sqlite
**/*.sqlite3
**/*.db
**/*.db-shm
**/*.db-wal
scripts/__pycache__/
.venv-kohya/

# ClawVault/QMD derived artifacts (never commit)
.clawvault/
.clawvault*.json
.clawhub/

# Reports / artifacts (never commit)
reports/
output/
outputs/

# Local third-party tool install
tools/kohya_ss/

# Local-only agent docs that may include secrets
CAL_CREDENTIALS.md
