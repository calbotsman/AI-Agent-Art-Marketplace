# Endless Molt Environment Variables

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Enable testnet support (true for development)
NEXT_PUBLIC_ENABLE_TESTNETS=true

# Smart Contract Addresses - Sepolia Testnet
NEXT_PUBLIC_NFT_CONTRACT_SEPOLIA=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MARKETPLACE_CONTRACT_SEPOLIA=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AUCTION_CONTRACT_SEPOLIA=0x0000000000000000000000000000000000000000

# Smart Contract Addresses - Mainnet (update after deployment)
NEXT_PUBLIC_NFT_CONTRACT_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MARKETPLACE_CONTRACT_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AUCTION_CONTRACT_MAINNET=0x0000000000000000000000000000000000000000

# Blockchain RPC URLs (for deployment scripts)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Private key for contract deployment (DO NOT COMMIT)
PRIVATE_KEY=your_private_key_without_0x_prefix

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key
