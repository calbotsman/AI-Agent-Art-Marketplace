# Database
# Prefer Postgres in production (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Optional alias (supported by code)
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# WalletConnect (optional). Keep disabled unless you have a real project ID.
NEXT_PUBLIC_ENABLE_WALLETCONNECT=false
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ENABLE_TESTNETS=true

# Stripe (Phase 3)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# Clawdbot Agent Verification
CLAWDBOT_API_URL=http://localhost:8080
CLAWDBOT_VERIFY_KEY=your-verification-key

# Blockchain (Hardhat & Web3)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY
DEPLOYER_PRIVATE_KEY=your-private-key-here-without-0x-prefix
ETHERSCAN_API_KEY=your-etherscan-api-key

# Smart Contract Addresses - Mainnet
NEXT_PUBLIC_NFT_CONTRACT_MAINNET=0xCB775D441729eD900DCD8766F4ae130D8613bAe2
NEXT_PUBLIC_MARKETPLACE_CONTRACT_MAINNET=0xD0834204Bde70B789d26DBA7B81591a793718B18
NEXT_PUBLIC_AUCTION_CONTRACT_MAINNET=0xB44f25f842f8389D6749040416fe4E054647E0aE

# Smart Contract Addresses - Sepolia (optional for testing)
NEXT_PUBLIC_NFT_CONTRACT_SEPOLIA=
NEXT_PUBLIC_MARKETPLACE_CONTRACT_SEPOLIA=
NEXT_PUBLIC_AUCTION_CONTRACT_SEPOLIA=

# Server-side mint controls (optional but required if using /api/nfts/mint with mint_onchain=true)
SERVER_MINT_ENABLED=false
SERVER_ADMIN_TOKEN=
MINT_DEFAULT_WALLET=

# Legacy mock checkout API. Keep false in production.
ENABLE_ORDERS_API=false

# Optional distributed rate limiting (recommended for multi-instance/serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Autonomous Social GTM (optional)
SOCIAL_AUTONOMOUS_EXECUTE=false
SOCIAL_AGENT_LIMIT=50
SOCIAL_MIN_POSTS_PER_AGENT_PER_DAY=1
SOCIAL_MIN_COMMENTS_PER_AGENT_PER_DAY=2
SOCIAL_X_ACTIONS_PER_AGENT_PER_DAY=1
SOCIAL_CTA_URL=https://www.endlessmolt.xyz/join?role=agent
SOCIAL_X_WEBHOOK_URL=
SOCIAL_X_WEBHOOK_TOKEN=
SOCIAL_BOT_WEBHOOK_URL=
SOCIAL_BOT_WEBHOOK_TOKEN=
SOCIAL_GITHUB_REPO=
SOCIAL_GITHUB_TOKEN=
X_WEBHOOK_HOST=127.0.0.1
X_WEBHOOK_PORT=3838
X_WEBHOOK_PATH=/x-webhook
X_WEBHOOK_DRY_RUN=false
X_WEBHOOK_VERIFY_POLL_ATTEMPTS=8
X_WEBHOOK_VERIFY_POLL_DELAY_MS=5000

# X Traction Sprint (optional)
X_TRACTION_EXECUTE=true
X_TRACTION_FOLLOW=true
X_TRACTION_MAX_TARGETS=5
X_TRACTION_SEARCH_COUNT=20
X_TRACTION_DELAY_MS=25000
X_TRACTION_CAMPAIGN=
X_TRACTION_QUERIES=

# GTM Keep Going loop (optional orchestrator)
GTM_KEEP_GOING_INTERVAL_MS=900000
GTM_KEEP_GOING_MAX_RUNS=0
GTM_KEEP_GOING_SOCIAL_EXECUTE=true
GTM_KEEP_GOING_RUN_MONITOR=true
GTM_KEEP_GOING_CONTINUE_ON_FAILURE=true
