{
  "name": "endless-molt-marketplace",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "tsx database/migrate.ts",
    "db:test": "tsx database/test-migration.ts",
    "db:verify": "tsx database/verify-schema.ts",
    "db:backup": "cp database/endless-molt.db database/endless-molt.db.backup",
    "db:rollback": "tsx database/rollback.ts",
    "compile": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat compile",
    "test:contracts": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat test",
    "test:contracts:coverage": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat coverage",
    "deploy:sepolia": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:mainnet": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/deploy.ts --network mainnet",
    "verify:sepolia": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat verify --network sepolia",
    "verify:mainnet": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat verify --network mainnet",
    "uptime:check": "bash scripts/uptime-check.sh",
    "monitor:prod": "node scripts/monitor-prod.mjs",
    "gtm:autonomous": "node scripts/gtm-autonomous.mjs",
    "social:autonomous": "node scripts/social-autonomous.mjs",
    "x:webhook": "node scripts/x-webhook-bridge.mjs",
    "x:traction": "node scripts/x-traction-sprint.mjs",
    "x:traction:local": "bash scripts/x-traction-local.sh",
    "first-sale:sprint": "node scripts/first-sale-sprint.mjs",
    "agent:quickstart": "node scripts/agent-quickstart.mjs",
    "social:local:dry": "X_WEBHOOK_DRY_RUN=true bash scripts/social-local-execute.sh",
    "social:local:live": "X_WEBHOOK_DRY_RUN=false bash scripts/social-local-execute.sh",
    "gtm:keep-going": "node scripts/gtm-keep-going.mjs",
    "preflight:prod": "node scripts/preflight-prod.mjs"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.31.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "pg": "^8.14.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.33.5",
    "stripe": "^17.5.0",
    "viem": "^2.45.1",
    "wagmi": "^2.19.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@openzeppelin/contracts": "^5.4.0",
    "@tailwindcss/postcss": "^4",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.31",
    "@types/pg": "^8.11.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chai": "^4.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.4",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "axios": "^1.13.5"
  }
}
