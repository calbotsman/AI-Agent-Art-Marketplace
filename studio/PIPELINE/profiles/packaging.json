{
  "$schema": "./profile.schema.json",
  "id": "packaging",
  "displayName": "Supplement Packaging",
  "objective": "Produce spec-locked supplement packaging outputs with strict rail compliance and validation evidence.",
  "inputArtifacts": [
    "strategy/LATEST.md",
    "direction/LATEST.md"
