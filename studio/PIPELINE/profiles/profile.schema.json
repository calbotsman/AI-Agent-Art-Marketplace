{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawd.local/studio/pipeline/profiles/profile.schema.json",
  "title": "Designer Task Profile",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "objective",
    "inputArtifacts",
    "systemRefs",
    "deliverables",
    "qaGates",
    "approvalFlow",
    "constraints"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "inputArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "systemRefs": {
      "type": "object",
      "required": [
        "designSystem",
        "validators",
        "workflowDocs"
      ],
      "properties": {
        "designSystem": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "workflowDocs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "qaGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approvalFlow": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "enum": [
          "strategy",
          "director",
          "designer",
          "validators"
        ]
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
