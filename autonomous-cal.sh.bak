#!/bin/bash
# Autonomous Cal - Continuous Development Loop

LOG_DIR="$HOME/clawd/logs"
TASK_FILE="$HOME/clawd/projects/products/endless-molt/TASK_LIST.md"
TODAY=$(date +%Y-%m-%d)
LOG_FILE="$LOG_DIR/DAILY_LOG_$TODAY.md"
TELEGRAM_BOT="@CalBotsmanBot"

case "$1" in
  morning)
    openclaw agent --to "$TELEGRAM_BOT" --message "Good morning Cal! Time for your daily standup:

1. Read ~/clawd/projects/products/endless-molt/TASK_LIST.md to see pending work
2. Review yesterday's progress in ~/clawd/logs/
3. Create today's plan
4. Send me a Telegram message with:
   - What was completed yesterday
   - What you plan to do today (list specific task numbers from TASK_LIST.md)
   - Any blockers
5. Start working on the highest priority task using your coding-agent skill

Remember: You're autonomous now. Work independently and update me via Telegram."
    ;;

  work)
    openclaw agent --message "Work session time Cal! Continue building:

1. Check ~/clawd/projects/products/endless-molt/TASK_LIST.md for your current task
2. If no task in progress, start the next high priority task (start with #1)
3. Use the coding-agent skill to implement features
4. When done, update TASK_LIST.md (mark completed, update status)
5. Commit your changes to git with detailed commit messages
6. Log progress to $LOG_FILE

Work autonomously. If blocked, notify me via Telegram and move to next task."
    ;;

  midday)
    openclaw agent --message "Mid-day progress check Cal:

1. Review progress since morning
2. Update ~/clawd/projects/products/endless-molt/TASK_LIST.md with current status
3. Send brief status via Telegram:
   - Tasks completed so far today
   - Current task in progress
   - Any issues or blockers
4. Continue working on current or next task"
    ;;

  evening)
    openclaw agent --message "End of day wrap-up Cal:

1. Commit all changes to git (if not already done)
2. Update ~/clawd/projects/products/endless-molt/TASK_LIST.md with final status
3. Write today's summary to $LOG_FILE including:
   - Tasks completed today
   - Tasks remaining
   - Any blockers encountered
4. Send evening report via Telegram with same info
5. Plan tomorrow's tasks

Great work today! Rest and resume tomorrow morning."
    ;;

  monitor)
    openclaw agent --message "Background monitoring Cal:

1. Check if ~/clawd/projects/products/endless-molt dev server is running
2. Look for any error logs in the project
3. If you find issues, try to fix them or alert me via Telegram
4. Keep systems running smoothly"
    ;;

  *)
    echo "Usage: $0 {morning|work|midday|evening|monitor}"
    echo ""
    echo "Commands:"
    echo "  morning  - Morning standup and planning"
    echo "  work     - Work session on tasks"
    echo "  midday   - Mid-day progress check"
    echo "  evening  - End of day wrap-up"
    echo "  monitor  - Background monitoring"
    exit 1
    ;;
esac
